# Server
PORT=3000
HOST=0.0.0.0
DATABASE_URL=file:./data/teamflow.db
JWT_SECRET=change-me-in-production-use-long-random-string
# Encrypts Discord bot token/PAT saved in Settings (falls back to JWT_SECRET if unset)
TEAMFLOW_SECRETS_KEY=
# Shared with apps/discord-bot/.env so the bot can fetch credentials from the API
TEAMFLOW_BOT_CONFIG_KEY=
PUBLIC_URL=http://localhost:3000

# Optional — password reset emails (if unset, reset links are logged on the server)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=teamflow@example.com

# Optional — issue file uploads (stored under data/uploads/)
# ATTACHMENT_MAX_IMAGE_BYTES=26214400
# ATTACHMENT_MAX_VIDEO_BYTES=4294967296
# ATTACHMENT_MAX_ZIP_BYTES=4294967296
# UPLOAD_CHUNK_BYTES=33554432
# UPLOAD_CHUNK_THRESHOLD_BYTES=8388608

# Web dev (Vite proxy target)
VITE_API_URL=http://localhost:3000

# MCP / CLI
TEAMFLOW_URL=http://localhost:3000
TEAMFLOW_TOKEN=
