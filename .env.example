# Server
PORT=3000
HOST=0.0.0.0
DATABASE_URL=file:./data/teamflow.db
JWT_SECRET=change-me-in-production-use-long-random-string
# Encrypts Discord bot token/PAT saved in Settings (falls back to JWT_SECRET if unset)
TEAMFLOW_SECRETS_KEY=
# Shared with apps/discord-bot/.env so the bot can fetch credentials from the API
TEAMFLOW_BOT_CONFIG_KEY=
PUBLIC_URL=http://localhost:3000

# Web dev (Vite proxy target)
VITE_API_URL=http://localhost:3000

# MCP / CLI
TEAMFLOW_URL=http://localhost:3000
TEAMFLOW_TOKEN=
