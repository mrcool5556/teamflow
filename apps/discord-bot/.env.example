DISCORD_BOT_TOKEN=
DISCORD_CLIENT_ID=

TEAMFLOW_URL=http://localhost:3000
TEAMFLOW_PUBLIC_URL=http://localhost:5173
TEAMFLOW_TOKEN=

# Default team UUID (from GET /teams with your PAT)
TEAMFLOW_TEAM_ID=

# Optional JSON: {"discordGuildId":"teamflowTeamUuid"}
# DISCORD_GUILD_TEAMS=

# Recommended: your Discord server ID for fast slash command updates
# DISCORD_REGISTER_GUILD_IDS=

# Thread transcripts (/create in threads, ticket starter text): enable Message Content
# Intent in Developer Portal → Bot → Privileged Gateway Intents, then set:
# DISCORD_MESSAGE_CONTENT_INTENT=true

# Optional env fallback if guild is not linked in Teamflow Settings → Discord bot
# DISCORD_ALLOWED_ROLE_IDS=123456789012345678,987654321098765432

# Optional: comma-separated channel IDs for ticket → issue (or configure in Settings UI)
# DISCORD_TICKET_CHANNEL_IDS=
