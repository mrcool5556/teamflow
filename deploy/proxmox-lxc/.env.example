PORT=3000
HOST=0.0.0.0
DATABASE_URL=file:./data/teamflow.db
JWT_SECRET=change-me-to-a-long-random-string
PUBLIC_URL=http://localhost:3000
# Optional — issue file uploads (defaults: images 25 MB, ZIPs 150 MB)
# ATTACHMENT_MAX_IMAGE_BYTES=26214400
# ATTACHMENT_MAX_ZIP_BYTES=157286400

SERVE_WEB=true
WEB_DIST=/opt/teamflow/apps/web/dist

# In-app backups & updates (Settings → Updates, Owner role)
TEAMFLOW_MAINTENANCE_ENABLED=true
TEAMFLOW_APP_DIR=/opt/teamflow
TEAMFLOW_BACKUP_DIR=/var/backups/teamflow
TEAMFLOW_MAINTENANCE_SUDO=true

# Optional — password reset emails
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=teamflow@example.com
